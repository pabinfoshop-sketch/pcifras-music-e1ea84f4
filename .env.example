# ============================================
# pCifras Music — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores.
# NOTA: No Freebuff, configure essas chaves na UI "Keys/API keys"
# em vez de editar .env diretamente.
# ============================================

# --- Supabase (OBRIGATÓRIO) ---
# URL do projeto Supabase
VITE_SUPABASE_URL=https://uqgulksbvwsxwimhjjrw.supabase.co
# Chave anônima/pública (anon key)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxx

# --- Supabase - Server-side (OBRIGATÓRIO para SSR/webhooks) ---
# URL do projeto Supabase (server-side)
SUPABASE_URL=https://uqgulksbvwsxwimhjjrw.supabase.co
# Service role key (para operações admin - NÃO exponha no frontend)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxx
# Chave pública/publishable (server-side)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxx

# --- Mercado Pago (OPCIONAL - para assinaturas) ---
# Access token do Mercado Pago
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxx
# Chave pública do Mercado Pago (frontend)
VITE_MP_PUBLIC_KEY=TEST-xxxxxxxxxxxxxxx

# --- URL Pública (OPCIONAL) ---
# Usada como fallback para URLs de retorno do Mercado Pago
PUBLIC_URL=http://localhost:5173
